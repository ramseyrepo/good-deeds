# Copy this file to .env.local and fill the values. Never commit .env.local.

# --- Database ---------------------------------------------------------------
# Postgres connection string. Local example:
#   postgresql://postgres:postgres@localhost:5432/souped_boilerplate?schema=public
DATABASE_URL=

# --- App --------------------------------------------------------------------
# Public URL of your deployed app (used in metadata, callbacks, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Souped auth ------------------------------------------------------------
# Auth is wired and active by default. `src/proxy.ts` gates `/app/*` and
# `/api/((?!auth).*)`; `/` and `/api/auth/*` stay public. See AGENTS.md →
# "Auth routing" for the full convention.
#
# Get these values from the Souped dashboard (https://build.souped.app)
# after creating a Web App, or from `glaze_get_project_auth_setup` over MCP.

# Glaze auth API URL — NOT the marketing site, NOT the dashboard.
# Value depends on the environment your Souped project lives in; get it
# from `glaze_get_project_auth_setup` over MCP (it returns the right
# host) or from the dashboard.
SOUPED_URL=
SOUPED_CLIENT_ID=
SOUPED_CLIENT_SECRET=
# Souped project ID (UUID). Required by @souped-tools/auth-nextjs.
SOUPED_APP_ID=
# Expected `aud` claim in JWTs issued for this project. Get it from
# `glaze_get_project_auth_setup` (MCP) or the Souped dashboard.
SOUPED_AUDIENCE=
# Expected `iss` claim in JWTs — the platform's stable identity,
# NOT the same as SOUPED_URL. Same source as SOUPED_AUDIENCE.
SOUPED_ISSUER=
# A 32+ char random string used to encrypt the session cookie.
# Generate one with: `openssl rand -base64 32`
SOUPED_SESSION_SECRET=

# --- Notifications (email channel via Resend) -------------------------------
# In production these are injected by the Resend Vercel Marketplace
# integration (run `vc i resend`). Leave unset locally to no-op the email
# channel — in-app notifications still work without them.
RESEND_API_KEY=
NOTIFICATIONS_EMAIL_FROM=
